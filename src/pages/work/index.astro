---
import { getCollection } from 'astro:content';
import Layout from '../../layouts/Layout.astro';
import WorkCard from '../../components/WorkCard.astro';

// Fetch all projects
const projects = await getCollection('projects');

// Categories definition
const categories = [
  { slug: 'all', label: 'All Work', count: projects.length },
  { slug: 'branding', label: 'Branding', count: projects.filter(p => p.data.categorySlug === 'branding').length },
  { slug: 'packaging', label: 'Packaging', count: projects.filter(p => p.data.categorySlug === 'packaging').length },
  { slug: 'web', label: 'Web Design', count: projects.filter(p => p.data.categorySlug === 'web').length },
  { slug: 'strategy', label: 'Strategy', count: projects.filter(p => p.data.categorySlug === 'strategy').length },
];
---

<Layout title="Work — Selected Projects" theme="chartreuse">
  <section class="section container" style="padding-top: calc(var(--header-h) + 60px);">
    <div class="reveal">
      <div class="eyebrow accent" style="margin-bottom:24px;">Portfolio</div>
      <h1 class="archive-h1" style="font-size: clamp(48px, 9vw, 140px); font-weight: 500; letter-spacing: -0.04em; line-height: 0.95; margin-bottom: 24px;">
        Selected<br>
        projects we're<br>
        <span class="italic" style="font-family:'Instrument Serif',serif; font-style:italic; font-weight:400; color:var(--accent);">proud</span> of.
      </h1>
      <p class="archive-sub" style="font-size: 18px; color: var(--text-2); max-width: 460px; line-height: 1.5; margin-bottom: 64px;">
        Eight years, twelve industries, and a persistent obsession with simple visual structures.
      </p>
    </div>

    <!-- Filter Bar -->
    <div class="filter-bar reveal" data-filter-bar style="display:flex; flex-wrap:wrap; gap:8px; border-bottom:1px solid var(--border); padding-bottom:32px; margin-bottom:48px;">
      {categories.map((c, i) => (
        <button class={`filter-btn ${i === 0 ? 'active' : ''}`} data-filter={c.slug}>
          <span class="dot"></span> {c.label} <span class="count">{c.count}</span>
        </button>
      ))}
    </div>

    <!-- Projects Grid -->
    <div class="work-grid reveal" data-archive-grid style="display:grid; grid-template-columns: repeat(auto-fill, minmax(400px, 1fr)); gap:24px;">
      {projects.map(project => (
        <WorkCard project={project} />
      ))}
    </div>
  </section>

  <!-- Client-side filtering script -->
  <script>
    function initFilters() {
      const bar = document.querySelector('[data-filter-bar]');
      const grid = document.querySelector('[data-archive-grid]');
      if (!bar || !grid) return;

      const buttons = bar.querySelectorAll('.filter-btn');
      const cards = grid.querySelectorAll('.work-card');

      buttons.forEach(btn => {
        btn.addEventListener('click', () => {
          // Reset active states
          buttons.forEach(b => b.classList.remove('active'));
          btn.classList.add('active');

          const filterValue = btn.getAttribute('data-filter');

          cards.forEach(card => {
            const cardEl = card as HTMLElement;
            const category = cardEl.getAttribute('data-cat');
            const show = filterValue === 'all' || category === filterValue;

            if (show) {
              cardEl.classList.remove('is-hidden');
              // Soft trigger for fade-in animation
              requestAnimationFrame(() => {
                cardEl.classList.remove('is-fading');
              });
            } else {
              cardEl.classList.add('is-fading');
              // Complete hide after transition ends
              setTimeout(() => {
                cardEl.classList.add('is-hidden');
              }, 280);
            }
          });
        });
      });
    }

    // Run
    initFilters();
    // Re-run for transitions
    document.addEventListener('astro:after-swap', initFilters);
  </script>
</Layout>
