---
import { getCollection, render } from 'astro:content';
import Layout from '../../layouts/Layout.astro';
import Lightbox from '../../components/Lightbox.astro';

export async function getStaticPaths() {
  const projects = await getCollection('projects');
  return projects.map((project, index) => {
    // Circular references for previous/next project navigators
    const prev = index > 0 ? projects[index - 1] : projects[projects.length - 1];
    const next = index < projects.length - 1 ? projects[index + 1] : projects[0];
    
    return {
      params: { slug: project.id },
      props: { project, prev, next },
    };
  });
}

const { project, prev, next } = Astro.props;
const { data, id } = project;
const { Content } = await render(project);

// Helper to safely render titles with dynamic italic words
const renderTitle = (title: string, italic?: string) => {
  if (!italic) return title;
  return title.replace(italic, `<span class="italic">${italic}</span>`);
};

// Check if a cover is explicitly set, otherwise use first image or fallback
const coverImage = data.cover || (data.images && data.images[0]?.includes('/') ? data.images[0] : null);
const hasRealImage = coverImage && coverImage.includes('/');
---

<Layout title={`${data.title} — Bosecrafts`} theme="chartreuse" description={data.tagline}>
  <section class="section container project-hero" style="padding-top: calc(var(--header-h) + 40px);">
    <div class="project-meta-top reveal">
      <a href="/work" class="btn-text">← All Work</a>
      <span class="eyebrow accent">{data.category} — {data.year}</span>
    </div>
    
    <h1 class="project-title reveal">
      <Fragment set:html={renderTitle(data.title, data.italic)} />
    </h1>
    
    <p class="project-tagline reveal">{data.tagline}</p>
    
    <!-- Meta fields row -->
    <div class="project-info reveal">
      <div class="info-row"><div class="info-label">Client</div><div class="info-value">{data.client}</div></div>
      <div class="info-row"><div class="info-label">Year</div><div class="info-value">{data.year}</div></div>
      <div class="info-row"><div class="info-label">Duration</div><div class="info-value">{data.duration}</div></div>
      <div class="info-row"><div class="info-label">Category</div><div class="info-value">{data.category}</div></div>
    </div>
    
    <!-- Hero Image / Placeholder -->
    <div class="project-hero-img reveal" style={`background: linear-gradient(135deg, ${data.accent}22 0%, ${data.accent}10 50%, ${data.accent}05 100%); display:flex; align-items:center; justify-content:center; border-radius: 24px; overflow:hidden; aspect-ratio:16/9; margin-bottom: 80px; position:relative; border: 1px solid var(--border);`}>
      {hasRealImage ? (
        <img style="width:100%; height:100%; object-fit:cover;" src={coverImage} alt={`${data.title} project hero`} />
      ) : (
        <div style={`font-family:'Instrument Serif',serif; font-style:italic; font-size:clamp(120px, 20vw, 400px); color:${data.accent}; opacity:0.4; line-height:1; user-select:none;`}>
          {data.title.charAt(0)}
        </div>
      )}
    </div>

    <!-- Body Layout -->
    <div class="project-body">
      <aside class="reveal">
        <h4>Services</h4>
        <ul>
          {data.services.map(s => (
            <li>{s}</li>
          ))}
        </ul>
      </aside>
      
      <div class="project-content reveal">
        {data.h3 && <h3>{data.h3}</h3>}
        <!-- Markdown compiled Content -->
        <Content />
      </div>
    </div>

    <!-- Case study galleries -->
    <div class="project-gallery reveal" style="display:grid; grid-template-columns: repeat(12, 1fr); gap:16px; margin-top: 80px;">
      {data.images.map((img, i) => {
        const spans = ['span-4', 'span-2', 'span-3', 'span-3', 'span-6', 'span-4'];
        const span = spans[i % spans.length] || 'span-4';
        const isPath = img.includes('/') || img.includes('.');

        return isPath ? (
          <a class={`g-item ${span}`} data-lightbox href={img} style="position:relative; border-radius:16px; overflow:hidden; border:1px solid var(--border); aspect-ratio:4/3; display:block;">
            <img src={img} alt={`${data.title} gallery image ${i + 1}`} loading="lazy" style="width:100%; height:100%; object-fit:cover; transition:transform 0.4s ease;" />
          </a>
        ) : (
          <a class={`g-item ${span}`} data-lightbox href="#" style={`display:flex; align-items:center; justify-content:center; background:linear-gradient(${(i * 47) % 360}deg, ${data.accent}30 0%, ${data.accent}08 100%); border-radius:16px; border:1px solid var(--border); aspect-ratio:4/3; text-decoration:none;`}>
            <span style={`font-family:'JetBrains Mono',monospace; color:${data.accent}; font-size:11px; letter-spacing:0.2em; text-transform:uppercase; opacity:0.6;`}>
              Frame {(i + 1).toString().padStart(2, '0')}
            </span>
          </a>
        );
      })}
    </div>
  </section>

  <!-- Prev/Next Navigation bar -->
  <div class="project-nav-bar" style="border-top:1px solid var(--border); display:flex; justify-content:space-between; align-items:center; margin-top:120px;">
    <a class="pn-link prev" href={`/work/${prev.id}`} style="flex:1; padding:48px; border-right:1px solid var(--border); text-align:left; display:flex; flex-direction:column; gap:8px; text-decoration:none; transition:background 0.3s ease;">
      <span class="pn-label" style="font-family:'JetBrains Mono',monospace; font-size:11px; text-transform:uppercase; color:var(--text-3); letter-spacing:0.1em;">← Previous</span>
      <span class="pn-title" style="font-size:clamp(18px, 2vw, 28px); font-weight:500;">
        <Fragment set:html={renderTitle(prev.data.title, prev.data.italic)} />
      </span>
    </a>
    <a class="pn-link next" href={`/work/${next.id}`} style="flex:1; padding:48px; text-align:right; display:flex; flex-direction:column; gap:8px; align-items:flex-end; text-decoration:none; transition:background 0.3s ease;">
      <span class="pn-label" style="font-family:'JetBrains Mono',monospace; font-size:11px; text-transform:uppercase; color:var(--text-3); letter-spacing:0.1em;">Next →</span>
      <span class="pn-title" style="font-size:clamp(18px, 2vw, 28px); font-weight:500;">
        <Fragment set:html={renderTitle(next.data.title, next.data.italic)} />
      </span>
    </a>
  </div>

  <!-- Fullscreen Lightbox logic -->
  <Lightbox />
</Layout>
