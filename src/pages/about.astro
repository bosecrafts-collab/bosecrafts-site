---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Studio — Bosecrafts" theme="chartreuse" description="The studio behind Bosecrafts — our values, our team, and our way of working.">
  <!-- ════ HERO ════ -->
  <section class="container about-hero" style="padding-top: calc(var(--header-h) + 60px); margin-bottom: 80px;">
    <span class="eyebrow accent reveal">The Studio · Est. 2017</span>
    <h1 class="reveal reveal-delay-1" style="font-size: clamp(48px, 9vw, 140px); font-weight: 500; letter-spacing: -0.04em; line-height: 0.95; margin-top: 24px; margin-bottom: 24px;">
      A small studio<br>
      with <span class="italic" style="font-family:'Instrument Serif',serif; font-style:italic; font-weight:400; color:var(--accent);">big</span><br>
      opinions.
    </h1>
    <p class="reveal reveal-delay-2" style="font-size:20px; color:var(--text-2); max-width:680px; line-height:1.55; margin-top:24px;">
      Bosecrafts is six people — three designers, a strategist, a writer, and an operator. We work out of a converted printing press in Siliguri's old quarter. We take on six to eight projects a year. We turn down twice as many.
    </p>
  </section>

  <!-- ════ MISSION ════ -->
  <section class="container" style="margin-bottom: 120px;">
    <div class="about-mission" style="display:grid; grid-template-columns: 1fr 1.5fr; gap:48px; border-top: 1px solid var(--border); padding-top: 48px;">
      <div class="reveal">
        <span class="eyebrow accent">Why we exist</span>
      </div>
      <div class="reveal reveal-delay-1" style="font-size: 18px; color: var(--text-2); line-height: 1.6; display:flex; flex-direction:column; gap:24px;">
        <p><strong style="color:var(--text); font-weight: 600;">Most agencies treat design as decoration.</strong> We treat it as infrastructure — load-bearing, slow to change, and capable of holding a business up for a decade.</p>
        <p>We're here for founders who want to build the kind of brand they'll be proud of in ten years. Not the kind that wins awards this quarter and feels dated by next.</p>
        <p>If that sounds like the work you want done, we'd like to hear about it.</p>
      </div>
    </div>
  </section>

  <!-- ════ VALUES ════ -->
  <section class="container" style="margin-bottom: 120px;">
    <div class="section-head reveal" style="margin-top:80px;">
      <div class="head-meta">
        <span class="eyebrow accent">Principles</span>
      </div>
      <h2>Three things we<br>won't <span class="italic" style="font-family:'Instrument Serif',serif; font-style:italic; font-weight:400; color:var(--accent);">compromise</span> on.</h2>
    </div>

    <div class="about-values" style="display:grid; grid-template-columns: repeat(3, 1fr); gap:16px;">
      <div class="value-card reveal" style="background: var(--bg-card); border: 1px solid var(--border); border-radius: 24px; padding: clamp(24px, 3vw, 40px); display:flex; flex-direction:column; gap:16px;">
        <div class="value-num" style="font-family:'JetBrains Mono',monospace; font-size:13px; color:var(--accent); font-weight:500;">01</div>
        <h3 style="font-size:24px; font-weight:500;">Strategy first.</h3>
        <p style="font-size:15px; color:var(--text-2); line-height:1.6;">Three weeks of thinking before a single pixel. The brief decides the work — not the other way around. We don't move into design until both sides have signed off.</p>
      </div>
      <div class="value-card reveal reveal-delay-1" style="background: var(--bg-card); border: 1px solid var(--border); border-radius: 24px; padding: clamp(24px, 3vw, 40px); display:flex; flex-direction:column; gap:16px;">
        <div class="value-num" style="font-family:'JetBrains Mono',monospace; font-size:13px; color:var(--accent); font-weight:500;">02</div>
        <h3 style="font-size:24px; font-weight:500;">Craft over speed.</h3>
        <p style="font-size:15px; color:var(--text-2); line-height:1.6;">Every brand we ship is reviewed against itself, twice, by someone who didn't make it. If the answer is "we can ship it tomorrow but it's 80%," we ship it next week at 100%.</p>
      </div>
      <div class="value-card reveal reveal-delay-2" style="background: var(--bg-card); border: 1px solid var(--border); border-radius: 24px; padding: clamp(24px, 3vw, 40px); display:flex; flex-direction:column; gap:16px;">
        <div class="value-num" style="font-family:'JetBrains Mono',monospace; font-size:13px; color:var(--accent); font-weight:500;">03</div>
        <h3 style="font-size:24px; font-weight:500;">Stay for the launch.</h3>
        <p style="font-size:15px; color:var(--text-2); line-height:1.6;">Six months of follow-through is baked into every engagement. We don't disappear after handover. The brand is yours to use, ours to make sure you can.</p>
      </div>
    </div>
  </section>

  <!-- ════ TEAM ════ -->
  <section class="container" style="padding-block:80px; margin-bottom: 80px;">
    <div class="section-head reveal">
      <div class="head-meta">
        <span class="eyebrow accent">Team</span>
      </div>
      <h2>The six of <span class="italic" style="font-family:'Instrument Serif',serif; font-style:italic; font-weight:400; color:var(--accent);">us.</span></h2>
    </div>

    <div style="display:grid; grid-template-columns:repeat(auto-fit, minmax(320px, 1fr)); gap:16px;" class="reveal">
      <!-- Tapas Bose -->
      <div class="value-card" style="text-align:left; background: var(--bg-card); border: 1px solid var(--border); border-radius: 24px; padding: clamp(24px, 3vw, 40px);">
        <div style="width:80px; height:80px; border-radius:50%; background:linear-gradient(135deg,#D9F65A 0%,#B8D63D 100%); display:flex; align-items:center; justify-content:center; font-family:'Instrument Serif',serif; font-style:italic; font-size:36px; color:var(--bg); margin-bottom:24px;">T</div>
        <h3 style="font-size:22px; font-weight:500;">Tapas Bose</h3>
        <p style="font-family:'JetBrains Mono',monospace; font-size:12px; color:var(--text-3); text-transform:uppercase; letter-spacing:0.1em; margin-top:4px;">Founder · Creative Director</p>
        <p style="margin-top:16px; font-size:14px; color:var(--text-2); line-height:1.6;">Twelve years at the intersection of design and business. Trained at NID; previously identity director at a Bangalore studio before moving back home.</p>
      </div>
      <!-- Aditi Sen -->
      <div class="value-card" style="text-align:left; background: var(--bg-card); border: 1px solid var(--border); border-radius: 24px; padding: clamp(24px, 3vw, 40px);">
        <div style="width:80px; height:80px; border-radius:50%; background:linear-gradient(135deg,#FF8FA3 0%,#FF5C5C 100%); display:flex; align-items:center; justify-content:center; font-family:'Instrument Serif',serif; font-style:italic; font-size:36px; color:var(--bg); margin-bottom:24px;">A</div>
        <h3 style="font-size:22px; font-weight:500;">Aditi Sen</h3>
        <p style="font-family:'JetBrains Mono',monospace; font-size:12px; color:var(--text-3); text-transform:uppercase; letter-spacing:0.1em; margin-top:4px;">Brand Strategist</p>
        <p style="margin-top:16px; font-size:14px; color:var(--text-2); line-height:1.6;">Background in market research and ethnography. Runs the discovery phase of every engagement. Asks the questions nobody wants to answer.</p>
      </div>
      <!-- Niraj Pradhan -->
      <div class="value-card" style="text-align:left; background: var(--bg-card); border: 1px solid var(--border); border-radius: 24px; padding: clamp(24px, 3vw, 40px);">
        <div style="width:80px; height:80px; border-radius:50%; background:linear-gradient(135deg,#FFC857 0%,#E76F51 100%); display:flex; align-items:center; justify-content:center; font-family:'Instrument Serif',serif; font-style:italic; font-size:36px; color:var(--bg); margin-bottom:24px;">N</div>
        <h3 style="font-size:22px; font-weight:500;">Niraj Pradhan</h3>
        <p style="font-family:'JetBrains Mono',monospace; font-size:12px; color:var(--text-3); text-transform:uppercase; letter-spacing:0.1em; margin-top:4px;">Senior Designer</p>
        <p style="margin-top:16px; font-size:14px; color:var(--text-2); line-height:1.6;">Typography obsessive. Spends weekends drawing letterforms. Has opinions on kerning that he's happy to share at length.</p>
      </div>
      <!-- Priya Lama -->
      <div class="value-card" style="text-align:left; background: var(--bg-card); border: 1px solid var(--border); border-radius: 24px; padding: clamp(24px, 3vw, 40px); margin-top: 16px;">
        <div style="width:80px; height:80px; border-radius:50%; background:linear-gradient(135deg,#7BC4C4 0%,#5BA8A8 100%); display:flex; align-items:center; justify-content:center; font-family:'Instrument Serif',serif; font-style:italic; font-size:36px; color:var(--bg); margin-bottom:24px;">P</div>
        <h3 style="font-size:22px; font-weight:500;">Priya Lama</h3>
        <p style="font-family:'JetBrains Mono',monospace; font-size:12px; color:var(--text-3); text-transform:uppercase; letter-spacing:0.1em; margin-top:4px;">Digital Designer</p>
        <p style="margin-top:16px; font-size:14px; color:var(--text-2); line-height:1.6;">Web and product. Figma evangelist. Builds prototypes faster than most people sketch. Cares deeply about how things actually feel to use.</p>
      </div>
      <!-- Mira Khan -->
      <div class="value-card" style="text-align:left; background: var(--bg-card); border: 1px solid var(--border); border-radius: 24px; padding: clamp(24px, 3vw, 40px); margin-top: 16px;">
        <div style="width:80px; height:80px; border-radius:50%; background:linear-gradient(135deg,#9C89B8 0%,#7A6B98 100%); display:flex; align-items:center; justify-content:center; font-family:'Instrument Serif',serif; font-style:italic; font-size:36px; color:var(--bg); margin-bottom:24px;">M</div>
        <h3 style="font-size:22px; font-weight:500;">Mira Khan</h3>
        <p style="font-family:'JetBrains Mono',monospace; font-size:12px; color:var(--text-3); text-transform:uppercase; letter-spacing:0.1em; margin-top:4px;">Copywriter</p>
        <p style="margin-top:16px; font-size:14px; color:var(--text-2); line-height:1.6;">Two years writing for a Mumbai literary magazine before joining us. Edits everything we ship. The brand voice runs through her.</p>
      </div>
      <!-- Dev Sharma -->
      <div class="value-card" style="text-align:left; background: var(--bg-card); border: 1px solid var(--border); border-radius: 24px; padding: clamp(24px, 3vw, 40px); margin-top: 16px;">
        <div style="width:80px; height:80px; border-radius:50%; background:linear-gradient(135deg,#FAFAFA 0%,#A3A3A3 100%); display:flex; align-items:center; justify-content:center; font-family:'Instrument Serif',serif; font-style:italic; font-size:36px; color:var(--bg); margin-bottom:24px;">D</div>
        <h3 style="font-size:22px; font-weight:500;">Dev Sharma</h3>
        <p style="font-family:'JetBrains Mono',monospace; font-size:12px; color:var(--text-3); text-transform:uppercase; letter-spacing:0.1em; margin-top:4px;">Studio Operations</p>
        <p style="margin-top:16px; font-size:14px; color:var(--text-2); line-height:1.6;">Makes sure deadlines exist, are real, and get hit. Manages the timelines, the budgets, and the inevitable scope conversations.</p>
      </div>
    </div>
  </section>

  <!-- ════ STATS ════ -->
  <section class="section container" style="margin-bottom: 80px;">
    <div class="stats-grid reveal">
      <div class="stat">
        <div class="stat-num" data-count>50+</div>
        <div class="stat-label">Brands Shipped</div>
      </div>
      <div class="stat">
        <div class="stat-num" data-count>8</div>
        <div class="stat-label">Years Operating</div>
      </div>
      <div class="stat">
        <div class="stat-num" data-count>94</div>
        <div class="stat-label">NPS Score</div>
      </div>
      <div class="stat">
        <div class="stat-num">6<span class="small">+</span></div>
        <div class="stat-label">People on Team</div>
      </div>
    </div>
  </section>

  <!-- ════ CTA ════ -->
  <section class="cta-section" style="border-top:1px solid var(--border);">
    <div class="container">
      <div class="cta-eye eyebrow accent">Work With Us</div>
      <h2 class="cta-headline">
        Like the way<br>
        we <span class="italic" style="font-family:'Instrument Serif',serif; font-style:italic; font-weight:400; color:var(--accent);">work?</span>
      </h2>
      <p class="cta-desc">We take on six to eight projects a year. Drop us a line and we'll see if there's a fit.</p>
      <div class="cta-buttons" style="margin-top:48px;">
        <a href="/contact" class="btn btn-primary" data-cursor="Start">
          <span>Start a Project</span>
          <span class="icon">↗</span>
        </a>
        <a href="/work" class="btn btn-ghost">
          <span>See our Work</span>
          <span class="icon">→</span>
        </a>
      </div>
    </div>
  </section>
</Layout>
