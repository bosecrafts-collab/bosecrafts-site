---
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import CustomCursor from '../components/CustomCursor.astro';

interface Props {
  title?: string;
  description?: string;
  theme?: string; // cobalt, ember, chartreuse, slate
}

const { 
  title = "Bosecrafts — Brands worth building.", 
  description = "A design-led consultancy from Siliguri building brands, identity systems, and digital experiences that command attention.",
  theme = "chartreuse"
} = Astro.props;
---

<!DOCTYPE html>
<html lang="en" data-theme={theme}>
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>{title}</title>
  <meta name="description" content={description}>
  <link rel="icon" href="data:image/svg+xml,%3Csvg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 100 100'%3E%3Ccircle cx='50' cy='50' r='50' fill='%23D9F65A'/%3E%3Ccircle cx='50' cy='50' r='30' fill='%230A0A0A'/%3E%3C/svg%3E">

  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&family=Instrument+Serif:ital@0;1&family=JetBrains+Mono:wght@300;400;500&display=swap" rel="stylesheet">

  <!-- Google tag (gtag.js) -->
  <script async src="https://www.googletagmanager.com/gtag/js?id=G-BH43BB9Z70"></script>
  <script is:inline>
    window.dataLayer = window.dataLayer || [];
    function gtag(){dataLayer.push(arguments);}
    gtag('js', new Date());

    gtag('config', 'G-BH43BB9Z70');
  </script>

  <meta name="theme-color" content="#FFFFFF">
  <script type="application/ld+json" is:inline>
    {
      "@context": "https://schema.org",
      "@type": "Organization",
      "name": "Bosecrafts",
      "url": "https://bosecrafts.in/",
      "logo": "https://bosecrafts.in/assets/img/site/logo.svg",
      "email": "bosecrafts@gmail.com",
      "address": {
        "@type": "PostalAddress",
        "addressLocality": "Siliguri",
        "addressRegion": "West Bengal",
        "addressCountry": "IN"
      }
    }
  </script>
</head>
<body>
  <!-- Custom interactive cursor -->
  <CustomCursor />

  <!-- Global Header -->
  <Header />

  <!-- Page Content Slots -->
  <slot />

  <!-- Global Footer -->
  <Footer />

  <!-- Lenis Smooth Scrolling Engine (loaded via CDN) -->
  <script is:inline src="https://unpkg.com/@studio-freight/lenis@1.0.42/dist/lenis.min.js"></script>
  <script is:inline>
    // Safe initialization
    if (typeof Lenis !== 'undefined') {
      const lenis = new Lenis({
        duration: 1.2,
        easing: (t) => Math.min(1, 1.001 - Math.pow(2, -10 * t)),
        smoothWheel: true,
        smoothTouch: false,
      });

      function raf(time) {
        lenis.raf(time);
        requestAnimationFrame(raf);
      }
      requestAnimationFrame(raf);
      
      // Store in window for accessibility
      window.lenis = lenis;
    }
  </script>

  <!-- Central Interactivity Bundler -->
  <script>
    import "../styles/global.css";
    import "../components/scripts/interactions.js";
  </script>
</body>
</html>
